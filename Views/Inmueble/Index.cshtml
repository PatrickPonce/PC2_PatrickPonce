@{
    ViewData["Title"] = "Catálogo de Inmuebles";
}

<h1>Catálogo de Inmuebles Activos</h1>

<div class="card p-3 mb-4">
    <h5 class="card-title">Filtros de Búsqueda</h5>
    <form asp-action="Index" method="get">
        <div class="row g-3">
            <div class="col-md-3">
                <label for="ciudad" class="form-label">Ciudad</label>
                <input type="text" name="ciudad" id="ciudad" class="form-control" value="@ViewData["Ciudad"]">
            </div>
            <div class="col-md-3">
                <label for="tipo" class="form-label">Tipo</label>
                <select name="tipo" id="tipo" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var type in Enum.GetValues(typeof(TipoInmueble)))
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label for="precioMin" class="form-label">Precio Mínimo</label>
                <input type="number" name="precioMin" id="precioMin" class="form-control" value="@ViewData["PrecioMin"]">
                <span asp-validation-for="precioMin" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label for="precioMax" class="form-label">Precio Máximo</label>
                <input type="number" name="precioMax" id="precioMax" class="form-control" value="@ViewData["PrecioMax"]">
                <span asp-validation-for="precioMax" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label for="dormitorios" class="form-label">Dormitorios >=</label>
                <input type="number" name="dormitorios" id="dormitorios" class="form-control" value="@ViewData["Dormitorios"]">
                <span asp-validation-for="dormitorios" class="text-danger"></span>
            </div>
        </div>
        <div class="d-flex justify-content-end mt-3">
            <button type="submit" class="btn btn-primary">Buscar</button>
        </div>
        <div asp-validation-summary="All" class="text-danger mt-3"></div>
    </form>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <img src="@item.Imagen" class="card-img-top" alt="@item.Titulo" style="height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title">@item.Titulo</h5>
                    <p class="card-text">
                        <strong>Ciudad:</strong> @item.Ciudad<br>
                        <strong>Precio:</strong> $@item.Precio<br>
                        <strong>Dormitorios:</strong> @item.Dormitorios
                    </p>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary">Ver Detalle</a>
                </div>
            </div>
        </div>
    }
</div>