@model PC2_PatrickPonce.ViewModels.FiltrosInmuebleViewModel
@{
    ViewData["Title"] = "Catálogo de Inmuebles";
}

<h1>Catálogo de Inmuebles Activos</h1>

<div class="card p-3 mb-4">
    <h5 class="card-title">Filtros de Búsqueda</h5>
    <form asp-action="Index" method="get">
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="Ciudad" class="form-label">Ciudad</label>
                <input asp-for="Ciudad" class="form-control">
                <span asp-validation-for="Ciudad" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Tipo" class="form-label">Tipo</label>
                <select asp-for="Tipo" asp-items="Html.GetEnumSelectList<TipoInmueble>()" class="form-select">
                    <option value="">Todos</option>
                </select>
                <span asp-validation-for="Tipo" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="PrecioMin" class="form-label">Precio Mínimo</label>
                <input asp-for="PrecioMin" type="number" class="form-control">
                <span asp-validation-for="PrecioMin" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="PrecioMax" class="form-label">Precio Máximo</label>
                <input asp-for="PrecioMax" type="number" class="form-control">
                <span asp-validation-for="PrecioMax" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="Dormitorios" class="form-label">Dormitorios >=</label>
                <input asp-for="Dormitorios" type="number" class="form-control">
                <span asp-validation-for="Dormitorios" class="text-danger"></span>
            </div>
        </div>
        <div class="d-flex justify-content-end mt-3">
            <button type="submit" class="btn btn-primary">Buscar</button>
        </div>
        <div asp-validation-summary="All" class="text-danger mt-3"></div>
    </form>
</div>

<div class="row">
    @foreach (var item in Model.Inmuebles)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <img src="@item.Imagen" class="card-img-top" alt="@item.Titulo" style="height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title">@item.Titulo</h5>
                    <p class="card-text">
                        <strong>Ciudad:</strong> @item.Ciudad<br>
                        <strong>Precio:</strong> $@item.Precio<br>
                        <strong>Dormitorios:</strong> @item.Dormitorios
                    </p>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary">Ver Detalle</a>
                </div>
            </div>
        </div>
    }
</div>